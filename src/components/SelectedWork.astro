---
import { projects } from '../data/projects';
---
<section id="work">
  <div class="container">
    <div class="section-header">
      <span class="label">Selected Work</span>
      <h2>Systems I've Built</h2>
    </div>
    <div class="work-grid">
      {projects.map((project) => (
        <div class="work-card glass">
          <div class="work-image-container">
             <div class="image-slider-track">
               {project.images.map(img => (
                 <div class="slide" style={`background-image: url(${img})`}></div>
               ))}
               {/* Clone first slide for seamless loop */}
               <div class="slide" style={`background-image: url(${project.images[0]})`}></div>
             </div>
             <div class="overlay">
               {project.tags.map(tag => <span class="tag">{tag}</span>)}
             </div>
          </div>
          <div class="work-content">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="work-focus">
              <strong>Focus:</strong> {project.focus}
            </div>
            <a href={`/work/${project.slug}`} class="btn-text">View Case Study →</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #work {
    padding: 120px 0;
  }

  .section-header {
    margin-bottom: 64px;
  }

  .label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    display: block;
    margin-bottom: 12px;
  }

  h2 {
    font-size: 40px;
    letter-spacing: -0.02em;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .work-card {
    position: relative;
    cursor: pointer;
    border-radius: 16px;
    overflow: hidden;
    background-color: var(--color-surface-container-low);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .work-card:hover {
    transform: translateY(-8px);
  }

  .work-image-container {
    height: 320px;
    background: var(--color-surface-container-high);
    position: relative;
    overflow: hidden;
  }

  .image-slider-track {
    display: flex;
    width: 400%; /* Default for 3 images + 1 clone */
    height: 100%;
    animation: slide-loop 16s infinite cubic-bezier(0.85, 0, 0.15, 1);
  }

  .slide {
    width: 25%;
    height: 100%;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    transition: transform 0.5s ease;
  }

  @keyframes slide-loop {
    0%, 22% { transform: translateX(0); }
    25%, 47% { transform: translateX(-25%); }
    50%, 72% { transform: translateX(-50%); }
    75%, 97% { transform: translateX(-75%); }
    100% { transform: translateX(-75%); }
  }

  /* Since I have 2 images + 1 clone, the loop should be:
     0-30%: Slide 1
     33-63%: Slide 2
     66-96%: Slide 1 (Clone)
     100%: Restart
  */

  .overlay {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    z-index: 10;
  }

  .tag {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-radius: 4px;
  }

  .work-content {
    padding: 32px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .work-content h3 {
    font-size: 24px;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
    min-height: 3.5rem; /* Ensures title height is consistent */
    display: flex;
    align-items: flex-start;
  }

  .work-content p {
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.8;
    margin-bottom: 24px;
    min-height: 4.8rem; /* Ensures description height is consistent */
    flex-grow: 1; /* Pushes the focus box and button to the bottom */
  }

  .work-focus {
    font-size: 14px;
    padding: 12px;
    background: var(--color-surface-container-highest);
    border-radius: 8px;
    margin-bottom: 24px;
  }

  .btn-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: gap 0.2s ease;
    display: inline-flex;
    align-items: center;
  }

  .btn-text::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .btn-text:hover {
    text-decoration: underline;
  }

  @media (max-width: 1200px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 800px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
