---
---
<nav class="glass">
  <div class="container nav-content">
    <div class="logo">
      <a href="/" class="logo-link">
        <span class="jade-text">Kushagra</span> <span class="middle-name">Vikram</span> <span class="last-name">Singh</span>
      </a>
    </div>
    <div class="nav-wrapper">
      <div class="links">
        <a href="/#work" class="active">Work</a>
        <a href="/#experiments">Experiments</a>
        <a href="/#about">About</a>
      </div>
      <a href="/#contact" class="btn-contact">Contact</a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 20px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.03);
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .logo-link {
    text-decoration: none;
    color: var(--color-on-surface);
    display: flex;
    gap: 4px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .logo-link:hover {
    transform: translateX(4px);
  }

  .jade-text {
    color: var(--color-primary);
    transition: all 0.4s ease;
  }

  .logo-link:hover .jade-text {
    text-shadow: 0 0 15px rgba(0, 78, 52, 0.1);
  }

  .middle-name, .last-name {
    color: var(--color-on-surface);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .logo-link:hover .middle-name {
    color: var(--color-primary);
  }

  .logo-link:hover .last-name {
    opacity: 0.5;
  }

  .nav-wrapper {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .links {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .links a {
    text-decoration: none;
    color: var(--color-on-surface);
    font-size: 14px;
    font-weight: 500;
    opacity: 0.6;
    transition: all 0.2s ease;
  }

  .links a:hover, .links a.active {
    opacity: 1;
  }

  .links a.active {
    position: relative;
  }

  .links a.active::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    right: 0;
    height: 1.5px;
    background-color: var(--color-primary);
    border-radius: 1px;
  }

  .btn-contact {
    background-color: var(--color-primary);
    color: white;
    padding: 10px 24px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-contact:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0, 78, 52, 0.15);
    background-color: #003a27;
  }

  @media (max-width: 768px) {
    .nav-content {
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
    }

    .nav-wrapper {
      width: 100%;
      justify-content: space-between;
      gap: 16px;
    }

    .links {
      gap: 16px;
    }

    .btn-contact {
      padding: 8px 16px;
      font-size: 12px;
    }

    .logo {
      font-size: 16px;
    }
  }

  @media (max-width: 480px) {
    .links a {
      font-size: 12px;
    }
    
    .nav-wrapper {
      gap: 8px;
    }
  }
</style>
