---
const experiments = [
  {
    title: "Constraint Solvers",
    description: "Optimizing for high-density requirements in scheduling and resource allocation."
  },
  {
    title: "LLM Workflows",
    description: "Bridging natural language and system actions for intuitive automation."
  },
  {
    title: "Visualizing Logic",
    description: "Making complex data and decision trees legible through clean visual design."
  }
];
---
<section id="experiments" class="alt">
  <div class="container">
    <div class="section-header">
      <span class="label">Explorations</span>
      <h2>AI + Systems Thinking</h2>
    </div>
    <div class="experiments-wrapper">
      <div class="grid-background"></div>
      <div class="experiments-grid">
        {experiments.map((exp, index) => (
          <div class="exp-card" style={`--index: ${index}`}>
            <div class="exp-visualizer">
              <div class={`viz-animation viz-${index}`}>
                <span></span><span></span><span></span><span></span>
              </div>
            </div>
            <div class="exp-header">
              <div class="exp-dot">
                <div class="ping"></div>
              </div>
              <h3>{exp.title}</h3>
            </div>
            <div class="exp-content">
              <p>{exp.description}</p>
            </div>
            <div class="card-status">
              <span class="status-text">SYSTEM_ACTIVE</span>
              <span class="status-code">0{index + 1}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #experiments {
    padding: 160px 0;
    position: relative;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .experiments-wrapper {
    position: relative;
    padding: 60px;
    background: rgba(0, 0, 0, 0.01);
    border-radius: 40px;
    border: 1px solid rgba(0, 0, 0, 0.03);
  }

  .grid-background {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0, 78, 52, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 78, 52, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
    pointer-events: none;
    animation: grid-move 20s linear infinite;
  }

  @keyframes grid-move {
    0% { background-position: 0 0; }
    100% { background-position: 40px 40px; }
  }

  .section-header {
    margin-bottom: 80px;
    text-align: center;
  }

  .label {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-primary);
    margin-bottom: 20px;
    display: inline-block;
  }

  h2 {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-on-surface);
  }

  .experiments-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    position: relative;
    z-index: 1;
  }

  .exp-card {
    padding: 40px;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 24px;
    position: relative;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    gap: 24px;
    opacity: 0;
    transform: translateY(30px);
    animation: reveal-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--index) * 0.2s);
  }

  @keyframes reveal-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .exp-card:hover {
    transform: translateY(-12px) scale(1.02);
    border-color: var(--color-primary);
    box-shadow: 0 30px 60px rgba(0, 78, 52, 0.08);
  }

  .exp-visualizer {
    height: 120px;
    width: 100%;
    background: rgba(0, 78, 52, 0.02);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  /* Animated Visuals */
  .viz-animation {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .viz-animation span {
    width: 4px;
    background: var(--color-primary);
    border-radius: 2px;
    opacity: 0.3;
  }

  /* Constraint Solver Viz */
  .viz-0 span {
    height: 20px;
    animation: viz-bar 1.5s infinite alternate ease-in-out;
  }
  .viz-0 span:nth-child(2) { animation-delay: 0.2s; height: 40px; }
  .viz-0 span:nth-child(3) { animation-delay: 0.4s; height: 30px; }
  .viz-0 span:nth-child(4) { animation-delay: 0.6s; height: 50px; }

  @keyframes viz-bar {
    0% { height: 10px; opacity: 0.2; }
    100% { height: 60px; opacity: 0.8; }
  }

  /* LLM Workflow Viz */
  .viz-1 {
    width: 60px;
    height: 60px;
    border: 2px dashed var(--color-primary);
    border-radius: 50%;
    animation: rotate 10s linear infinite;
    position: relative;
  }
  .viz-1::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12px;
    height: 12px;
    background: var(--color-primary);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 20px var(--color-primary);
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Visualizing Logic Viz */
  .viz-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  .viz-2 span {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    animation: pulse-grid 2s infinite alternate;
  }
  .viz-2 span:nth-child(2) { animation-delay: 0.5s; }
  .viz-2 span:nth-child(3) { animation-delay: 1s; }
  .viz-2 span:nth-child(4) { animation-delay: 1.5s; }

  @keyframes pulse-grid {
    0% { transform: scale(0.8); opacity: 0.2; }
    100% { transform: scale(1.2); opacity: 0.8; background: var(--color-primary); }
  }

  .exp-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .exp-dot {
    width: 10px;
    height: 10px;
    background-color: var(--color-primary);
    border-radius: 50%;
    position: relative;
  }

  .ping {
    position: absolute;
    inset: -4px;
    border: 1px solid var(--color-primary);
    border-radius: 50%;
    animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping {
    75%, 100% { transform: scale(2.5); opacity: 0; }
  }

  .exp-content h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-on-surface);
  }

  .exp-content p {
    font-size: 15px;
    line-height: 1.6;
    opacity: 0.6;
  }

  .card-status {
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .status-text {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    opacity: 0.5;
  }

  .status-code {
    font-family: monospace;
    font-size: 12px;
    opacity: 0.3;
  }

  @media (max-width: 1024px) {
    .experiments-grid {
      grid-template-columns: 1fr;
    }
    .experiments-wrapper {
      padding: 30px;
    }
  }
</style>
