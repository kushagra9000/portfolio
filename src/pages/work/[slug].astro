---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Kushagra VS`}>
  <Navigation />
  
  <main class="case-study-page">
    <header class="hero">
      <div class="container">
        <a href="/#work" class="back-link">← Back to Work</a>
        <div class="hero-content">
          <div class="tags">
            {project.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
          <h1>
            {project.slug === 'torqup' ? (
              <span class="animated-torqup-title chrome-text">
                {project.title} — {project.details.subtitle}
              </span>
            ) : (
              <>{project.title} — {project.details.subtitle}</>
            )}
          </h1>
          <p class="lead">{project.description}</p>
          
          <div class="hero-actions-wrapper">
            {project.slug !== 'torqup' && project.externalLink && (
              <div class="hero-actions">
                <a href={project.externalLink} target="_blank" rel="noopener noreferrer" class="btn-external glass">
                  Visit Live Site 
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3.5 10.5L10.5 3.5M10.5 3.5H3.5M10.5 3.5V10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            )}

            {project.slug === 'torqup' && (
              <div class="hero-actions torqup-dual-actions">
                <a href="https://torqup.in" target="_blank" rel="noopener noreferrer" class="btn-external globe-btn">
                  <span class="btn-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                  </span>
                  Visit torqup.in
                  <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3.5 10.5L10.5 3.5M10.5 3.5H3.5M10.5 3.5V10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
                <a href="https://play.google.com/store/apps/details?id=com.fluxorlabs.torqup.app&pcampaignid=web_share" target="_blank" rel="noopener noreferrer" class="btn-external playstore-btn">
                  <span class="btn-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L18.89,13.92C19.59,13.52 20,12.79 20,12C20,11.21 19.59,10.48 18.89,10.08L16.81,8.88L14.39,11.3L16.81,15.12M13,12L13.69,12L14.39,12.7L15.42,14.33L4.54,20.58L13,12M15.42,9.67L14.39,11.3L13.69,12L13,12L4.54,3.42L15.42,9.67Z" /></svg>
                  </span>
                  Get it on Play Store
                  <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3.5 10.5L10.5 3.5M10.5 3.5H3.5M10.5 3.5V10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </header>

    <section class="overview">
      <div class="container asymmetric-grid">
        <div class="problem-space">
          <div class="content-block">
            <span class="label">The Challenge</span>
            <h2>The Problem</h2>
            <p>{project.details?.problem}</p>
          </div>
          
          {project.details?.challenges && (
            <div class="content-block challenges">
              <h2>Why Existing Solutions Fail</h2>
              <div class="challenges-grid">
                {project.details.challenges.map(challenge => (
                  <div class="challenge-item">
                    <h3>{challenge.title}</h3>
                    <ul>
                      {challenge.points.map(point => <li>{point}</li>)}
                    </ul>
                  </div>
                ))}
              </div>
              <div class="gap-highlight card glass">
                <strong>The Gap:</strong> No system is designed for intermittent connectivity environments.
              </div>
            </div>
          )}
        </div>

        <div class="meta-sidebar-container">
          <div class="meta-sidebar card glass">
            <div class="meta-item">
              <h3>Focus</h3>
              <p>{project.focus}</p>
            </div>
            <div class="meta-item">
              <h3>Tech Stack</h3>
              <ul class="tech-list">
                {project.details?.techStack.map(tech => <li>{tech}</li>)}
              </ul>
            </div>
            {project.details?.outcome && (
              <div class="meta-item">
                <h3>Outcome</h3>
                <p>{project.details.outcome}</p>
              </div>
            )}
            {project.details?.credibility && (
              <div class="meta-item credibility">
                <h3>Context</h3>
                <p><em>{project.details.credibility}</em></p>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    {project.details?.solution && (
      <section class="solution-overview alt">
        <div class="container">
          <div class="solution-grid">
            <div class="solution-text">
              <span class="label">The System Response</span>
              <h2>The Solution</h2>
              <p class="large-p">{project.details.solution}</p>
            </div>
            
            {project.details.hybridDesign && (
              <div class="hybrid-design-card card glass">
                <div class="card-inner">
                  <h3>Hybrid System Design</h3>
                  <p>{project.details.hybridDesign}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    {project.details?.systemFlow && (
      <section class="system-flow alt">
        <div class="container">
          <div class="section-header">
            <span class="label">Architecture</span>
            <h2>System Flow</h2>
          </div>
          <div class="flow-track">
            {project.details.systemFlow.map((step, index) => (
              <div class="flow-step card glass">
                <div class="step-number">{index + 1}</div>
                <p>{step}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="features">
      <div class="container">
        <div class="section-header">
          <span class="label">Deep Dive</span>
          <h2>Key Features</h2>
        </div>
        <div class="features-grid">
          {project.details?.features.map(feature => (
            <div class="feature-card card glass">
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {(project.details?.realWorldContext || project.details?.fieldInsights) && (
      <section class="insights alt">
        <div class="container asymmetric-grid">
          {project.details?.realWorldContext && (
            <div class="insight-block">
              <span class="label">Realities</span>
              <h2>Designing for Reality</h2>
              <ul class="insight-list">
                {project.details.realWorldContext.map(item => <li>{item}</li>)}
              </ul>
            </div>
          )}
          {project.details?.fieldInsights && (
            <div class="insight-block">
              <span class="label">Validation</span>
              <h2>Field Insights</h2>
              <ul class="insight-list">
                {project.details.fieldInsights.map(item => <li>{item}</li>)}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    {project.images && project.images.length > 0 && (
      <section class="gallery">
        <div class="container">
          <div class="section-header">
            <span class="label">Visuals</span>
            <h2>Gallery</h2>
          </div>
          <div class="image-grid">
            {project.images.map(img => (
              <div class="gallery-item glass">
                <img src={img} alt={project.title} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="cta">
      <div class="container">
        <div class="cta-card card glass">
          {project.details?.closingStatement ? (
            <div class="closing-statement">
              <h2>Building for Impact</h2>
              <p class="final-positioning">{project.details.closingStatement}</p>
            </div>
          ) : (
            <>
              <h2>Have a project in mind?</h2>
              <p>Let's build something extraordinary together.</p>
            </>
          )}
          <a href="mailto:kushagravs24@gmail.com" class="btn-primary">Get in Touch</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .case-study-page {
    padding-top: 80px;
  }

  .hero {
    padding: 100px 0 60px;
    background-color: var(--color-surface-container-low);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 40px;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    transition: transform 0.2s ease;
  }

  .back-link:hover {
    transform: translateX(-4px);
  }

  .hero-content h1 {
    font-size: 56px;
    margin: 24px 0;
    max-width: 900px;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 32px;
      margin: 16px 0;
    }

    .lead {
      font-size: 16px;
    }
  }

  .hero-actions {
    margin-top: 40px;
  }

  .btn-external {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 20px rgba(0, 78, 52, 0.2);
    position: relative;
    overflow: hidden;
  }

  .btn-external::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    transform: rotate(45deg);
    transition: 0.5s;
    pointer-events: none;
  }

  .btn-external:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 30px rgba(0, 78, 52, 0.3);
    background: var(--color-primary-container);
  }

  .btn-external:hover::after {
    left: 120%;
  }

  /* Specific Button Styles */
  .globe-btn {
    background: #000 !important;
    color: #fff !important;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .playstore-btn {
    background: #fff !important;
    color: #000 !important;
    border: 1px solid rgba(0,0,0,0.1);
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .btn-external:hover .btn-icon {
    transform: scale(1.2) rotate(5deg);
  }

  /* Animated Title for TorqUp */
  .chrome-text {
    background: linear-gradient(
      to right,
      #1a1a1a 20%,
      #888 40%,
      #1a1a1a 60%,
      #888 80%,
      #1a1a1a 100%
    ) !important;
    background-size: 200% auto !important;
    background-clip: text !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    animation: shine 6s linear infinite !important;
    display: inline-block !important;
  }

  @keyframes shine {
    from { background-position: 0% center; }
    to { background-position: 200% center; }
  }

  .torqup-dual-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn-external {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  .globe-btn:hover {
    background: #111 !important;
    border-color: rgba(255,255,255,0.3) !important;
    transform: translateY(-4px) scale(1.02) !important;
  }

  .playstore-btn:hover {
    background: #fcfcfc !important;
    border-color: rgba(0,0,0,0.3) !important;
    transform: translateY(-4px) scale(1.02) !important;
  }

  .btn-external:hover .arrow {
    transform: translate(3px, -3px) !important;
  }

  .btn-external .arrow {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-external:hover .arrow {
    transform: translate(2px, -2px);
  }

  .btn-external svg {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-external:hover svg {
    transform: translate(2px, -2px);
  }

  .lead {
    font-size: 20px;
    opacity: 0.8;
    max-width: 700px;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 12px;
  }

  .tag {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 6px 12px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-radius: 6px;
  }

  .asymmetric-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .overview {
    padding: 120px 0 80px;
  }

  .content-block {
    margin-bottom: 80px;
  }

  .content-block h2 {
    font-size: 40px;
    margin: 16px 0 32px;
    color: var(--color-on-surface);
  }

  .content-block p {
    font-size: 20px;
    line-height: 1.7;
    opacity: 0.9;
    color: var(--color-on-surface);
  }

  .meta-sidebar {
    padding: 48px;
    background: var(--color-surface-container-highest);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 24px;
    position: sticky;
    top: 120px;
  }

  .meta-item h3 {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.4;
    margin-bottom: 16px;
  }

  .tech-list li {
    font-size: 13px;
    font-weight: 600;
    padding: 6px 12px;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 8px;
  }

  /* Challenges Section */
  .challenges {
    margin-top: 80px;
  }

  .challenges-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin: 40px 0;
  }

  .challenge-item h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
    color: var(--color-on-surface);
  }

  .challenge-item ul {
    list-style: none;
    padding: 0;
  }

  .challenge-item li {
    font-size: 16px;
    opacity: 0.7;
    margin-bottom: 12px;
    padding-left: 24px;
    position: relative;
    line-height: 1.5;
  }

  .challenge-item li::before {
    content: "✕";
    position: absolute;
    left: 0;
    color: #e57373;
    font-size: 12px;
    top: 4px;
  }

  .gap-highlight {
    padding: 32px;
    border-left: 4px solid var(--color-primary);
    background: var(--color-surface-container-highest);
    font-size: 20px;
    line-height: 1.6;
    border-radius: 0 16px 16px 0;
    margin-top: 40px;
  }

  /* Solution Section - High Impact Block */
  .solution-overview {
    padding: 160px 0;
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    position: relative;
    overflow: hidden;
  }

  .solution-overview::before {
    content: "";
    position: absolute;
    top: -10%;
    right: -5%;
    width: 40%;
    height: 120%;
    background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .solution-overview .label {
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    font-size: 12px;
  }

  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 120px;
    align-items: center;
  }

  .solution-text h2 {
    font-size: 64px;
    margin: 24px 0 32px;
    color: white;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  @media (max-width: 768px) {
    .solution-text h2 {
      font-size: 36px;
      margin: 16px 0 24px;
    }

    .large-p {
      font-size: 18px;
    }

    .solution-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  .large-p {
    font-size: 26px;
    line-height: 1.5;
    opacity: 0.9;
    font-weight: 450;
    color: rgba(255, 255, 255, 0.9);
  }

  .hybrid-design-card {
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(30px);
    border-radius: 40px;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.2);
  }

  .card-inner {
    padding: 72px;
  }

  .hybrid-design-card h3 {
    font-size: 32px;
    margin-bottom: 28px;
    color: white;
    letter-spacing: -0.01em;
  }

  .hybrid-design-card p {
    font-size: 19px;
    line-height: 1.8;
    opacity: 0.85;
    color: white;
  }

  /* Utility Classes */
  .label {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  /* System Flow */
  .system-flow {
    padding: 120px 0;
  }

  .flow-track {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
  }

  .flow-step {
    padding: 40px;
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .step-number {
    width: 32px;
    height: 32px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }

  .flow-step p {
    font-size: 18px;
    line-height: 1.5;
    margin: 0;
  }

  /* Features Section */
  .features {
    padding: 140px 0;
    background: var(--color-surface-container-low);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
  }

  .feature-card {
    padding: 48px;
  }

  .feature-card h3 {
    font-size: 24px;
    margin-bottom: 16px;
    color: var(--color-primary);
  }

  .feature-card p {
    font-size: 18px;
    line-height: 1.6;
    opacity: 0.8;
  }

  /* Field Insights */
  .insights {
    padding: 140px 0;
  }

  .insight-list {
    list-style: none;
    padding: 0;
    margin-top: 32px;
  }

  .insight-list li {
    font-size: 20px;
    margin-bottom: 24px;
    padding-left: 32px;
    position: relative;
    line-height: 1.4;
  }

  .insight-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }
  /* Gallery Section */
  .gallery {
    padding: 140px 0;
  }

  .image-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
  }

  .gallery-item {
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16/10;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  /* CTA Section */
  .cta {
    padding: 160px 0;
    text-align: center;
  }

  .cta-card {
    padding: 100px 48px;
    max-width: 900px;
    margin: 0 auto;
  }

  .cta h2 {
    font-size: 56px;
    margin-bottom: 24px;
    color: var(--color-on-surface);
    line-height: 1.1;
  }

  @media (max-width: 768px) {
    .cta h2 {
      font-size: 32px;
    }

    .cta p {
      font-size: 16px;
    }

    .cta-card {
      padding: 60px 24px;
    }
  }

  .cta p {
    font-size: 20px;
    opacity: 0.7;
    margin-bottom: 48px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 1200px) {
    .solution-grid {
      gap: 60px;
    }
    .solution-text h2 {
      font-size: 48px;
    }
  }

  @media (max-width: 992px) {
    .asymmetric-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    
    .solution-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .flow-track,
    .features-grid,
    .image-grid {
      grid-template-columns: 1fr;
    }

    .solution-text h2 {
      font-size: 40px;
    }

    .cta h2 {
      font-size: 36px;
    }
  }
</style>
