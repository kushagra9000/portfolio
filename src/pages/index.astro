---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import SelectedWork from '../components/SelectedWork.astro';
import InteractiveTimetable from '../components/InteractiveTimetable.astro';
import AIExperiments from '../components/AIExperiments.astro';
---

<Layout title="Kushagra VS | Systems Designer & Builder">
	<main>
		<Navigation />
		<Hero />
    <section class="impact-section">
      <div class="container">
        <div class="section-label">
          <span class="label">Engineering Impact</span>
          <h2 class="impact-title">Building for Complexity & Scale</h2>
        </div>
        
        <div class="impact-carousel-container">
          <div class="impact-track">
            <!-- Original Set -->
            <div class="impact-card">
              <div class="card-number">2+</div>
              <div class="card-content">
                <h3>Production Products</h3>
                <p class="subtitle">Built and shipped end-to-end</p>
                <div class="card-description">
                  Designed, developed, and deployed full-scale applications from scratch—handling everything from system architecture and UX to backend logic and production deployment.
                </div>
                <div class="card-footer">
                  Delivered real-world systems in healthcare (LIMS) and consumer platforms (automotive).
                </div>
              </div>
            </div>

            <div class="impact-card">
              <div class="card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7L12 12L22 7L12 2Z"></path><path d="M2 17L12 22L22 17"></path><path d="M2 12L12 17L22 12"></path></svg>
              </div>
              <div class="card-content">
                <h3>AI + Systems Design</h3>
                <p class="subtitle">Timetables · LIMS · Automation</p>
                <div class="card-description">
                  Architected systems that go beyond interfaces—focusing on how data flows, decisions are made, and constraints are handled.
                </div>
                <div class="card-footer">
                  Scheduling optimization and automation pipelines combining algorithmic thinking.
                </div>
              </div>
            </div>

            <div class="impact-card">
              <div class="card-number">0→1</div>
              <div class="card-content">
                <h3>Execution</h3>
                <p class="subtitle">From idea to working software</p>
                <div class="card-description">
                  Took products from initial concept to production—validating problems, defining system architecture, building core features, and iterating based on usage.
                </div>
                <div class="card-footer">
                  Bridging product thinking, engineering, and UX to bring ideas to life.
                </div>
              </div>
            </div>

            <!-- Cloned Set for Seamless Loop -->
            <div class="impact-card">
              <div class="card-number">2+</div>
              <div class="card-content">
                <h3>Production Products</h3>
                <p class="subtitle">Built and shipped end-to-end</p>
                <div class="card-description">
                  Designed, developed, and deployed full-scale applications from scratch—handling everything from system architecture and UX to backend logic and production deployment.
                </div>
                <div class="card-footer">
                  Delivered real-world systems in healthcare (LIMS) and consumer platforms (automotive).
                </div>
              </div>
            </div>

            <div class="impact-card">
              <div class="card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7L12 12L22 7L12 2Z"></path><path d="M2 17L12 22L22 17"></path><path d="M2 12L12 17L22 12"></path></svg>
              </div>
              <div class="card-content">
                <h3>AI + Systems Design</h3>
                <p class="subtitle">Timetables · LIMS · Automation</p>
                <div class="card-description">
                  Architected systems that go beyond interfaces—focusing on how data flows, decisions are made, and constraints are handled.
                </div>
                <div class="card-footer">
                  Scheduling optimization and automation pipelines combining algorithmic thinking.
                </div>
              </div>
            </div>

            <div class="impact-card">
              <div class="card-number">0→1</div>
              <div class="card-content">
                <h3>Execution</h3>
                <p class="subtitle">From idea to working software</p>
                <div class="card-description">
                  Took products from initial concept to production—validating problems, defining system architecture, building core features, and iterating based on usage.
                </div>
                <div class="card-footer">
                  Bridging product thinking, engineering, and UX to bring ideas to life.
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="impact-bottom-banner">
          <div class="banner-content">
            <strong>Real-World Problem Solving:</strong> Focused on building for imperfect environments—prioritizing robustness, simplicity, and practical usability over theoretical perfection.
          </div>
        </div>
      </div>
    </section>

    <SelectedWork />
		<InteractiveTimetable />
    <AIExperiments />
		
    <section id="contact" class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-left">
            <div class="cta-header">
              <span class="label">Ready to execute?</span>
              <h2 class="massive-title">Let's build the <span class="jade-text-animated">future of systems.</span></h2>
              <p class="cta-subtitle">Currently exploring new collaborations. If you have a complex problem to solve or a system to build, let's talk.</p>
            </div>

            <div class="footer-brand-info">
              <div class="logo">
                <span class="jade-text">Kushagra</span> <span class="name-part">Vikram</span> <span class="name-part">Singh</span>
              </div>
              <p class="tagline">Systems Designer & Builder specializing in high-impact AI products and production-grade software.</p>
              
              <div class="social-links-minimal">
                <a href="https://github.com/kushagra9000" target="_blank" class="social-link">GitHub ↗</a>
                <a href="https://linkedin.com/in/kvs24" target="_blank" class="social-link">LinkedIn ↗</a>
              </div>
            </div>
          </div>

          <div class="footer-right">
            <div class="form-container">
              <form id="contact-form" class="minimal-form">
                <div class="form-group">
                  <label for="full-name">Name</label>
                  <input type="text" id="full-name" name="name" placeholder="John Doe" required />
                </div>
                
                <div class="form-group">
                  <label for="email-address">Email Address</label>
                  <input type="email" id="email-address" name="email" placeholder="john@example.com" required />
                </div>

                <div class="form-group">
                  <label for="project-type">What are we building?</label>
                  <select id="project-type" name="project-type">
                    <option value="product">Product from 0 to 1</option>
                    <option value="system">System Architecture</option>
                    <option value="ai">AI Integration</option>
                    <option value="other">Something else</option>
                  </select>
                </div>

                <div class="form-group">
                  <label for="message">Message</label>
                  <textarea id="message" name="message" placeholder="Tell me about the project..." required></textarea>
                </div>

                <button type="submit" class="btn-submit" id="submit-btn">
                  <span class="btn-text">Send Message</span>
                  <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>

                <!-- Status Messages (Bottom positioned, strictly hidden) -->
                <div id="form-status-success" class="status-message success" style="display: none;"></div>
                <div id="form-status-error" class="status-message error" style="display: none;"></div>
              </form>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <p class="copyright">© 2026 Systems Designer & Builder. All rights reserved.</p>
          <div class="status-badge">
            <span class="dot"></span>
            Available for new opportunities
          </div>
        </div>
      </div>
    </section>

    <!-- Formspree Integration -->
    <script is:inline>
      const contactForm = document.getElementById('contact-form');
      const successMessage = document.getElementById('form-status-success');
      const errorMessage = document.getElementById('form-status-error');
      const submitBtn = document.getElementById('submit-btn');

      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // UI State: Loading
        submitBtn.disabled = true;
        const btnText = submitBtn.querySelector('.btn-text');
        const originalBtnText = btnText.textContent;
        btnText.textContent = 'Sending...';

        const formData = new FormData(contactForm);
        
        try {
          const response = await fetch('https://formspree.io/f/xbdqpvll', {
            method: 'POST',
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          });

          if (response.ok) {
            // Success
            successMessage.textContent = "Thanks! Your message has been sent successfully.";
            successMessage.style.display = 'flex';
            errorMessage.style.display = 'none';
            contactForm.querySelectorAll('.form-group, #submit-btn').forEach(el => el.style.display = 'none');
          } else {
            const data = await response.json();
            throw new Error(data.error || 'Submission failed');
          }
        } catch (err) {
          // Error
          errorMessage.textContent = "Oops! There was a problem. Please try again.";
          errorMessage.style.display = 'flex';
          submitBtn.disabled = false;
          btnText.textContent = originalBtnText;
        }
      });
    </script>
	</main>
</Layout>

<style>
	.footer {
		padding: 140px 0 80px;
		background-color: var(--color-surface-container-high);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
	}

  .massive-title {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.1;
    margin-top: 24px;
    max-width: 800px;
    letter-spacing: -0.04em;
    font-weight: 800;
  }

  .jade-text-animated {
    color: var(--color-primary);
    position: relative;
    display: inline-block;
  }

  .jade-text-animated::after {
    content: '';
    position: absolute;
    bottom: 8px;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--color-primary);
    opacity: 0.2;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer:hover .jade-text-animated::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 100px;
    margin-bottom: 100px;
    align-items: center; /* Vertically balance left and right */
  }

  .cta-subtitle {
    font-size: 18px;
    opacity: 0.6;
    margin-top: 24px;
    line-height: 1.6;
    max-width: 480px;
  }

  .footer-brand-info {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  .social-links-minimal {
    display: flex;
    gap: 32px;
    margin-top: 32px;
  }

  .social-link {
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-on-surface);
    opacity: 0.4;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .social-link:hover {
    opacity: 1;
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  /* Form Styles */
  .form-container {
    background: var(--color-surface-container-highest);
    padding: 32px; /* Reduced from 48px to fix 'too tall' issue */
    border-radius: 32px;
    position: relative;
    overflow: hidden;
  }

  .minimal-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 16px;
    border-radius: 12px;
    font-family: var(--font-main);
    font-size: 16px;
    color: var(--color-on-surface);
    transition: all 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    background: white;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(0, 78, 52, 0.05);
  }

  .form-group textarea {
    height: 120px;
    resize: none;
  }

  .btn-submit {
    background: var(--color-on-surface);
    color: white;
    border: none;
    padding: 20px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 8px;
  }

  .btn-submit:hover {
    background: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 78, 52, 0.2);
  }

  .btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .btn-icon {
    transition: transform 0.4s ease;
  }

  .btn-submit:hover .btn-icon {
    transform: translate(4px, -4px) rotate(10deg);
  }

  /* Status Messages */
  .status-message {
    display: none;
    align-items: center;
    gap: 16px;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 15px;
    font-weight: 600;
  }

  /* Only show when Formspree injects text */
  .status-message:not(:empty) {
    display: flex;
  }

  .status-message.success {
    background: rgba(0, 78, 52, 0.05);
    color: var(--color-primary);
    border: 1px solid rgba(0, 78, 52, 0.1);
  }

  .status-message.error {
    background: rgba(255, 0, 0, 0.05);
    color: #d32f2f;
    border: 1px solid rgba(255, 0, 0, 0.1);
  }

  /* Formspree SDK hide/show logic */
  [data-fs-success]:empty,
  [data-fs-error]:empty {
    display: none !important;
  }

	.logo {
		font-size: 28px;
		font-weight: 800;
		margin-bottom: 28px;
    display: flex;
    gap: 8px;
    letter-spacing: -0.02em;
	}

  .name-part {
    color: var(--color-on-surface);
  }

	.jade-text {
		color: var(--color-primary);
	}

	.footer-brand .tagline {
		font-size: 18px;
		opacity: 0.6;
    line-height: 1.6;
    max-width: 440px;
	}

	.footer-links {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 60px;
	}

	.link-group h4 {
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		margin-bottom: 36px;
		opacity: 0.4;
    font-weight: 800;
	}

	.link-group a {
		display: block;
		text-decoration: none;
		color: var(--color-on-surface);
		font-size: 17px;
		margin-bottom: 20px;
		font-weight: 500;
		transition: all 0.3s ease;
    position: relative;
    width: fit-content;
	}

  .arrow {
    display: inline-block;
    opacity: 0;
    transform: translate(-10px, 10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    font-size: 14px;
    margin-left: 6px;
  }

  .link-group a:hover {
    color: var(--color-primary);
    transform: translateX(10px);
  }

  .link-group a:hover .arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  .impact-section {
		padding: 120px 0;
		background-color: var(--color-surface);
	}

  .section-label {
    margin-bottom: 64px;
    text-align: center;
  }

  .impact-title {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-top: 12px;
  }

  .impact-carousel-container {
    overflow: hidden;
    width: 100%;
    position: relative;
    padding: 20px 0;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .impact-track {
    display: flex;
    gap: 32px;
    width: max-content;
    animation: scroll 30s linear infinite;
  }

  .impact-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - 16px));
    }
  }

  .impact-card {
    background: var(--color-surface-container-low);
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 40px;
    border-radius: 24px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 400px; /* Fixed width for carousel consistency */
    flex-shrink: 0;
  }

  .impact-card:hover {
    transform: translateY(-8px) scale(1.02);
    background: white;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
    border-color: var(--color-primary);
  }

  .card-number {
    font-size: 48px;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .card-icon {
    width: 48px;
    height: 48px;
    background: rgba(0, 78, 52, 0.05);
    color: var(--color-primary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .impact-card h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--color-on-surface);
  }

  .card-content .subtitle {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
  }

  .card-description {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-on-surface);
    opacity: 0.7;
    margin-bottom: 24px;
  }

  .card-footer {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.5;
    padding-top: 20px;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    opacity: 0.5;
  }

  .impact-bottom-banner {
    background: var(--color-on-surface);
    color: white;
    padding: 32px 48px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 64px;
  }

  .banner-content {
    font-size: 16px;
    line-height: 1.5;
    text-align: center;
    max-width: 800px;
  }

  .banner-content strong {
    color: var(--color-primary);
    margin-right: 8px;
  }

	.logo-strip-section {
		padding: 60px 0 100px;
		background-color: var(--color-surface);
	}

	.divider {
		height: 1px;
		background-color: rgba(0, 0, 0, 0.05);
		margin-bottom: 40px;
	}

	.logo-strip {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 40px;
	}

	.logo-strip .label {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.12em;
		color: #999;
		white-space: nowrap;
	}

	.logo-items {
		display: flex;
		gap: 60px;
		align-items: center;
		flex: 1;
		justify-content: flex-end;
	}

	.logo-item {
		display: flex;
		align-items: center;
		gap: 16px;
		color: #777;
		transition: color 0.3s ease;
	}

  .metric-val {
    font-size: 24px;
    font-weight: 800;
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
  }

  .metric-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .metric-text strong {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-on-surface);
  }

  .metric-text span {
    font-size: 12px;
    opacity: 0.6;
  }

	.logo-item:hover {
		color: var(--color-on-surface);
	}

	@media (max-width: 1024px) {
    .impact-card {
      width: 320px;
    }
    .impact-bottom-banner {
      border-radius: 24px;
      padding: 32px;
    }
		.logo-strip {
			flex-direction: column;
			gap: 32px;
			align-items: flex-start;
		}
    
    .logo-items {
      gap: 40px;
      flex-wrap: wrap;
      justify-content: flex-start;
    }
	}

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 60px;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  .copyright {
    font-size: 14px;
    opacity: 0.4;
    font-weight: 500;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    background: rgba(0, 78, 52, 0.05);
    color: var(--color-primary);
    border-radius: 100px;
    border: 1px solid rgba(0, 78, 52, 0.1);
  }

  .dot {
    width: 10px;
    height: 10px;
    background: var(--color-primary);
    border-radius: 50%;
    position: relative;
  }

  .dot::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: inherit;
    border-radius: inherit;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .massive-title {
      font-size: 48px;
    }
    .form-container {
      padding: 32px;
    }
    .footer-brand-info {
      margin-top: 40px;
      padding-top: 40px;
    }
  }
</style>
